@page "/"
@using FormMaker.Client.Components
@inject NavigationManager Navigation

<PageTitle>Form Maker - Build Professional Forms with Ease</PageTitle>

<!-- Spacer for fixed header -->
<div style="height: 64px;"></div>

<main class="page-fade-in">
<MudContainer MaxWidth="MaxWidth.Large" Style="padding-top: 64px; padding-bottom: 80px;">
    <!-- Hero Section -->
    <div style="text-align: center; margin-bottom: 80px;">
        <MudText Typo="Typo.h2" Class="premium-header-text mb-6" Style="font-size: clamp(2.5rem, 5vw, 4rem) !important;">
            Craft Professional Forms <br /> <span class="auth-header-gradient">In Minutes</span>
        </MudText>
        <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mb-10 mx-auto" Style="max-width: 700px; font-weight: 400; line-height: 1.6;">
            A powerful, accessible drag-and-drop builder designed for everyone.
            From simple RSVPs to complex business applications.
        </MudText>

        <!-- Main CTA Buttons -->
        <div class="d-flex justify-center gap-6 flex-wrap mb-12">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.RocketLaunch"
                       OnClick='@(() => Navigation.NavigateTo("forms"))'
                       Class="premium-btn px-8 py-4"
                       Style="height: 60px; font-size: 1.1rem;">
                Get Started Free
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Size="Size.Large"
                       StartIcon="@Icons.Material.Filled.AutoAwesome"
                       OnClick='@(() => Navigation.NavigateTo("templates"))'
                       Class="premium-btn px-8 py-4"
                       Style="height: 60px; font-size: 1.1rem; border-width: 2px;">
                Explore Templates
            </MudButton>
        </div>
    </div>

    <!-- Feature Highlights -->
    <div class="text-center mb-12">
        <MudText Typo="Typo.h4" Class="premium-header-text mb-4">Why Form Maker?</MudText>
        <div class="mx-auto rounded-pill mb-12" style="width: 60px; height: 4px; background: var(--premium-primary);"></div>
    </div>

    <MudGrid Spacing="6">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="premium-card pa-10 text-center d-flex flex-column" Style="height: 100%;">
                <div class="mb-6 p-4 rounded-xl d-inline-block mx-auto" style="background: #eef2ff;">
                    <MudIcon Icon="@Icons.Material.Filled.TouchApp" Color="Color.Primary" Style="font-size: 48px;" />
                </div>
                <MudText Typo="Typo.h5" Class="premium-header-text mb-4">Click & Drag</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Style="line-height: 1.7;">
                    The most intuitive builder on the market. Click elements to customize and drag them anywhere on the canvas.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="premium-card pa-10 text-center d-flex flex-column" Style="height: 100%;">
                <div class="mb-6 p-4 rounded-xl d-inline-block mx-auto" style="background: #f0fdf4;">
                    <MudIcon Icon="@Icons.Material.Filled.AccessibilityNew" Color="Color.Success" Style="font-size: 48px;" />
                </div>
                <MudText Typo="Typo.h5" Class="premium-header-text mb-4">Inclusive Design</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Style="line-height: 1.7;">
                    Optimized for elderly and non-technical users. Large touch targets and screen-reader compatibility built-in.
                </MudText>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="premium-card pa-10 text-center d-flex flex-column" Style="height: 100%;">
                <div class="mb-6 p-4 rounded-xl d-inline-block mx-auto" style="background: #fff7ed;">
                    <MudIcon Icon="@Icons.Material.Filled.Phonelink" Color="Color.Warning" Style="font-size: 48px;" />
                </div>
                <MudText Typo="Typo.h5" Class="premium-header-text mb-4">Export Anywhere</MudText>
                <MudText Typo="Typo.body1" Color="Color.Secondary" Style="line-height: 1.7;">
                    Share links instantly or export your forms to high-quality PDF. Your data stays synchronized securely.
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <!-- Final CTA -->
    <div class="mt-16 text-center pa-12 rounded-xl" style="background: linear-gradient(135deg, #594ae2 0%, #7e57c2 100%); position: relative; overflow: hidden;">
        <div style="position: absolute; top: -50px; right: -50px; width: 200px; height: 200px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
        <div style="position: absolute; bottom: -20px; left: -20px; width: 100px; height: 100px; background: rgba(255,255,255,0.1); border-radius: 50%;"></div>
        
        <MudText Typo="Typo.h3" Style="font-weight: 700; color: white; margin-bottom: 24px;">Ready to create?</MudText>
        <MudText Typo="Typo.body1" Style="color: rgba(255,255,255,0.9); margin-bottom: 40px; font-size: 1.25rem;">
            Join thousands of users building professional forms today.
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Default"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Bolt"
                   OnClick='@(() => Navigation.NavigateTo("register"))'
                   Class="premium-btn px-10 py-4"
                   Style="height: 60px; font-size: 1.1rem; background: white; color: var(--premium-primary);">
            Get Started Now
        </MudButton>
    </div>
</MudContainer>
</main>

@code {
    // No code needed for landing page
}
