    private void DuplicateSelectedElement()
    {
        // Get all selected elements from current page
        var currentElements = currentTemplate.IsMultiPage && currentTemplate.CurrentPage != null
            ? currentTemplate.CurrentPage.Elements
            : currentTemplate.Elements;
        var selectedElements = currentElements.Where(e => e.IsSelected).ToList();

        if (!selectedElements.Any())
        {
            Snackbar.Add("No element selected to duplicate", Severity.Warning);
            return;
        }

        RecordHistory(); // Record state before duplication

        // Clear current selection on current page
        if (currentTemplate.IsMultiPage && currentTemplate.CurrentPage != null)
        {
            currentTemplate.CurrentPage.ClearSelection();
        }
        else
        {
            currentTemplate.ClearSelection();
        }

        List<FormElement> newElements = new();

        foreach (var element in selectedElements)
        {
            // Serialize and deserialize for deep copy
            var json = System.Text.Json.JsonSerializer.Serialize(element);
            var duplicatedElement = System.Text.Json.JsonSerializer.Deserialize<FormElement>(json);

            if (duplicatedElement != null)
            {
                // Generate new ID
                duplicatedElement.Id = Guid.NewGuid();

                // Offset position so it's visible (20px down and right)
                duplicatedElement.X += 20;
                duplicatedElement.Y += 20;

                // Ensure it stays within canvas bounds
                if (duplicatedElement.X + duplicatedElement.Width > currentTemplate.WidthInPixels)
                {
                    duplicatedElement.X = currentTemplate.WidthInPixels - duplicatedElement.Width - 10;
                }
                if (duplicatedElement.Y + duplicatedElement.Height > currentTemplate.HeightInPixels)
                {
                    duplicatedElement.Y = currentTemplate.HeightInPixels - duplicatedElement.Height - 10;
                }

                // Add new element to current page and select it
                if (currentTemplate.IsMultiPage && currentTemplate.CurrentPage != null)
                {
                    currentTemplate.CurrentPage.AddElement(duplicatedElement);
                }
                else
                {
                    currentTemplate.AddElement(duplicatedElement);
                }
                duplicatedElement.IsSelected = true;
                newElements.Add(duplicatedElement);
            }
        }

        // Update selected element (last duplicated for properties panel)
        if (newElements.Any())
        {
            selectedElement = newElements.Last();
        }

        hasUnsavedChanges = true;

        if (newElements.Count == 1)
        {
            Snackbar.Add($"{newElements[0].GetDisplayName()} duplicated", Severity.Success);
        }
        else
        {
            Snackbar.Add($"{newElements.Count} elements duplicated", Severity.Success);
        }

        StateHasChanged();
    }

