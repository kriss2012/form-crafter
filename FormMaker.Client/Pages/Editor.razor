    private void DeleteSelectedElement()
    {
        // Get selected elements from current page
        var currentElements = currentTemplate.IsMultiPage && currentTemplate.CurrentPage != null
            ? currentTemplate.CurrentPage.Elements
            : currentTemplate.Elements;
        var selectedElements = currentElements.Where(e => e.IsSelected).ToList();

        if (selectedElements.Count == 0)
        {
            return;
        }

        RecordHistory(); // Record state before delete

        foreach (var element in selectedElements)
        {
            // Remove from current page
            if (currentTemplate.IsMultiPage && currentTemplate.CurrentPage != null)
            {
                currentTemplate.CurrentPage.RemoveElement(element.Id);
            }
            else
            {
                currentTemplate.RemoveElement(element.Id);
            }
        }

        if (selectedElements.Count == 1)
        {
            Snackbar.Add($"{selectedElements[0].GetDisplayName()} deleted", Severity.Success);
        }
        else
        {
            Snackbar.Add($"{selectedElements.Count} elements deleted", Severity.Success);
        }

        selectedElement = null;
        hasUnsavedChanges = true;
        StateHasChanged();
    }

    private async Task SaveForm()
    {
        try
        {
            // Serialize the template to JSON
            var jsonData = JsonSerializer.Serialize(currentTemplate);

            // Check if this is a new template or updating existing
            if (currentTemplate.Id == Guid.Empty)
            {
                // Create new template via API
                var request = new FormMaker.Client.Services.CreateTemplateRequest
                {
                    Name = currentTemplate.Name,
                    Description = "", // TODO: Add description field to UI
                    JsonData = jsonData,
                    Category = "Custom",
                    Tags = "",
                    IsPublic = false
                };

                var response = await ApiService.PostAsync<FormMaker.Client.Services.CreateTemplateRequest, FormMaker.Client.Services.TemplateResponse>("templates", request);

                if (response != null)
                {
                    // Update the current template ID with the server-generated ID
                    currentTemplate.Id = response.Id;
                    hasUnsavedChanges = false;
                    lastSaveTime = DateTime.Now;
                    Snackbar.Add($"'{currentTemplate.Name}' created successfully!", Severity.Success);
                }
            }
            else
            {
                // Update existing template via API
                var request = new FormMaker.Client.Services.UpdateTemplateRequest
                {
                    Name = currentTemplate.Name,
                    Description = "", // TODO: Add description field to UI
                    JsonData = jsonData,
                    Category = "Custom",
                    Tags = "",
                    IsPublic = false
                };

                var response = await ApiService.PutAsync<FormMaker.Client.Services.UpdateTemplateRequest, FormMaker.Client.Services.TemplateResponse>($"templates/{currentTemplate.Id}", request);

                if (response != null)
                {
                    hasUnsavedChanges = false;
                    lastSaveTime = DateTime.Now;
                    Snackbar.Add($"'{currentTemplate.Name}' saved successfully!", Severity.Success);
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving form: {ex.Message}", Severity.Error);
        }
    }

    private async Task AutoSave()
    {
        if (hasUnsavedChanges && currentTemplate.Elements.Count > 0)
        {
            try
            {
                // Serialize the template to JSON
                var jsonData = JsonSerializer.Serialize(currentTemplate);

                // Check if this is a new template or updating existing
                if (currentTemplate.Id == Guid.Empty)
                {
                    // Create new template via API
                    var request = new FormMaker.Client.Services.CreateTemplateRequest
                    {
                        Name = currentTemplate.Name,
                        Description = "",
                        JsonData = jsonData,
                        Category = "Custom",
                        Tags = "",
                        IsPublic = false
                    };

                    var response = await ApiService.PostAsync<FormMaker.Client.Services.CreateTemplateRequest, FormMaker.Client.Services.TemplateResponse>("templates", request);

                    if (response != null)
                    {
                        // Update the current template ID with the server-generated ID
                        currentTemplate.Id = response.Id;
                        hasUnsavedChanges = false;
                        lastSaveTime = DateTime.Now;

                        // Show subtle notification for auto-save
                        await InvokeAsync(() =>
                        {
                            Snackbar.Add("Auto-saved", Severity.Info, config =>
                            {
                                config.VisibleStateDuration = 1000;
                            });
                            StateHasChanged();
                        });
                    }
                }
                else
                {
                    // Update existing template via API
                    var request = new FormMaker.Client.Services.UpdateTemplateRequest
                    {
                        Name = currentTemplate.Name,
                        Description = "",
                        JsonData = jsonData,
                        Category = "Custom",
                        Tags = "",
                        IsPublic = false
                    };

                    var response = await ApiService.PutAsync<FormMaker.Client.Services.UpdateTemplateRequest, FormMaker.Client.Services.TemplateResponse>($"templates/{currentTemplate.Id}", request);

                    if (response != null)
                    {
                        hasUnsavedChanges = false;
                        lastSaveTime = DateTime.Now;

                        // Show subtle notification for auto-save
                        await InvokeAsync(() =>
                        {
                            Snackbar.Add("Auto-saved", Severity.Info, config =>
                            {
                                config.VisibleStateDuration = 1000;
                            });
                            StateHasChanged();
                        });
                    }
                }
            }
            catch
            {
                // Silently fail auto-save, user can manually save
            }
        }
    }

