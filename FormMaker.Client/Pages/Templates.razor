@page "/templates"
@using FormMaker.Client.Components
@inject NavigationManager Navigation

<PageTitle>Template Gallery - Form Maker</PageTitle>

<SharedAppBar />

<!-- Spacer for fixed header -->
<div style="height: 64px;"></div>

<main class="page-fade-in">
<MudContainer MaxWidth="MaxWidth.Large" Style="padding-top: 48px; padding-bottom: 64px;">
    <!-- Page Header -->
    <div class="mb-12">
        <MudText Typo="Typo.h3" Class="premium-header-text mb-4">Template Gallery</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Style="font-size: 20px; max-width: 600px;">
            Jumpstart your productivity with professionally designed form templates.
        </MudText>
    </div>

    <!-- Category Tabs -->
    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Class="mb-8" PanelClass="pa-6" Style="background: transparent;">
        <MudTabPanel Text="All" Icon="@Icons.Material.Filled.Apps" />
        <MudTabPanel Text="Business" Icon="@Icons.Material.Filled.Business" />
        <MudTabPanel Text="Legal" Icon="@Icons.Material.Filled.Gavel" />
        <MudTabPanel Text="HR" Icon="@Icons.Material.Filled.People" />
        <MudTabPanel Text="Events" Icon="@Icons.Material.Filled.Event" />
        <MudTabPanel Text="General" Icon="@Icons.Material.Filled.Description" />
    </MudTabs>

    <!-- Coming Soon State -->
    <div class="d-flex flex-column align-center justify-center py-16 px-8 rounded-xl" style="background: rgba(255,255,255,0.6); backdrop-filter: blur(10px); border: 1px solid var(--premium-glass-border); box-shadow: var(--premium-shadow);">
        <div class="mb-8 p-6 rounded-circle" style="background: white; box-shadow: 0 10px 25px -5px rgba(89, 74, 226, 0.1);">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size: 80px; color: var(--premium-primary);" />
        </div>
        
        <MudText Typo="Typo.h4" Class="premium-header-text mb-4">Crafting the Gallery</MudText>
        
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-10 text-center" Style="max-width: 650px; font-size: 1.1rem; line-height: 1.6;">
            We're curating a collection of industry-standard templates for HR, Legal, and Business needs. 
            Stay tuned for the <strong>Phase 6</strong> release featuring one-click form generation.
        </MudText>

        <!-- Preview Chips -->
        <div class="d-flex flex-wrap justify-center gap-3 mb-12" style="max-width: 800px;">
            @foreach (var label in new[] { "Job Application", "Authorization", "Consent Form", "Event RSVP", "Leave Request", "Quotation", "Feedback", "Timesheet" })
            {
                <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Style="background: white; border: 1px solid #e2e8f0; font-weight: 500;">@label</MudChip>
            }
        </div>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   Size="Size.Large"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick='@(() => Navigation.NavigateTo("editor"))'
                   Class="premium-btn px-10 py-4">
            Build from Scratch
        </MudButton>
    </div>
</MudContainer>
</main>

