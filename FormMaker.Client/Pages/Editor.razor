    private void CopySelectedElement()
    {
        // Get all selected elements from current page
        var currentElements = currentTemplate.IsMultiPage && currentTemplate.CurrentPage != null
            ? currentTemplate.CurrentPage.Elements
            : currentTemplate.Elements;
        var selectedElements = currentElements.Where(e => e.IsSelected).ToList();

        if (!selectedElements.Any())
        {
            Snackbar.Add("No element selected to copy", Severity.Warning);
            return;
        }

        // Clear clipboard and copy all selected elements
        clipboardElements.Clear();

        foreach (var element in selectedElements)
        {
            // Serialize for deep copy to clipboard
            var json = System.Text.Json.JsonSerializer.Serialize(element);
            var copiedElement = System.Text.Json.JsonSerializer.Deserialize<FormElement>(json);
            if (copiedElement != null)
            {
                clipboardElements.Add(copiedElement);
            }
        }

        if (selectedElements.Count == 1)
        {
            Snackbar.Add($"{selectedElements[0].GetDisplayName()} copied to clipboard", Severity.Info);
        }
        else
        {
            Snackbar.Add($"{selectedElements.Count} elements copied to clipboard", Severity.Info);
        }
    }

    private void PasteElement()
    {
        if (!clipboardElements.Any())
        {
            Snackbar.Add("Nothing to paste", Severity.Warning);
            return;
        }

        RecordHistory(); // Record state before paste

        // Clear current selection on current page
        if (currentTemplate.IsMultiPage && currentTemplate.CurrentPage != null)
        {
            currentTemplate.CurrentPage.ClearSelection();
        }
        else
        {
            currentTemplate.ClearSelection();
        }

        List<FormElement> newElements = new();

        foreach (var clipboardElement in clipboardElements)
        {
            // Serialize and deserialize for deep copy
            var json = System.Text.Json.JsonSerializer.Serialize(clipboardElement);
            var pastedElement = System.Text.Json.JsonSerializer.Deserialize<FormElement>(json);

            if (pastedElement != null)
            {
                // Generate new ID
                pastedElement.Id = Guid.NewGuid();

                // Offset position so it's visible (20px down and right from the copied element)
                pastedElement.X += 20;
                pastedElement.Y += 20;

                // Ensure it stays within canvas bounds
                if (pastedElement.X + pastedElement.Width > currentTemplate.WidthInPixels)
                {
                    pastedElement.X = currentTemplate.WidthInPixels - pastedElement.Width - 10;
                }
                if (pastedElement.Y + pastedElement.Height > currentTemplate.HeightInPixels)
                {
                    pastedElement.Y = currentTemplate.HeightInPixels - pastedElement.Height - 10;
                }

                // Add new element to current page and select it
                if (currentTemplate.IsMultiPage && currentTemplate.CurrentPage != null)
                {
                    currentTemplate.CurrentPage.AddElement(pastedElement);
                }
                else
                {
                    currentTemplate.AddElement(pastedElement);
                }
                pastedElement.IsSelected = true;
                newElements.Add(pastedElement);
            }
        }

        // Update selected element (last pasted for properties panel)
        if (newElements.Any())
        {
            selectedElement = newElements.Last();
        }

        // Update clipboard to the new pasted elements for repeated pastes
        clipboardElements.Clear();
        foreach (var newElement in newElements)
        {
            var json = System.Text.Json.JsonSerializer.Serialize(newElement);
            var copiedElement = System.Text.Json.JsonSerializer.Deserialize<FormElement>(json);
            if (copiedElement != null)
            {
                clipboardElements.Add(copiedElement);
            }
        }

        hasUnsavedChanges = true;

        if (newElements.Count == 1)
        {
            Snackbar.Add($"{newElements[0].GetDisplayName()} pasted", Severity.Success);
        }
        else
        {
            Snackbar.Add($"{newElements.Count} elements pasted", Severity.Success);
        }

        StateHasChanged();
    }

