@page "/forms"
@attribute [Authorize]
@using FormMaker.Client.Services
@using FormMaker.Client.Components
@using FormMaker.Shared.Models

<PageTitle>My Forms - Form Maker</PageTitle>

<!-- Global Navigation -->
<SharedAppBar />

<!-- Spacer for fixed header -->
<div style="height: 64px;"></div>

<main aria-label="My forms page" class="page-fade-in">
<MudContainer MaxWidth="MaxWidth.Large" Style="padding-top: 48px; padding-bottom: 48px;">
    <!-- Header -->
    <div class="d-flex justify-space-between align-center mb-10">
        <div>
            <MudText Typo="Typo.h3" Class="premium-header-text mb-2">My Workspace</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">
                Create, manage, and share your forms effortlessly
            </MudText>
        </div>

        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick='@(() => Navigation.NavigateTo("editor"))'
                   Size="Size.Large"
                   Class="premium-btn px-6 py-3"
                   aria-label="Create new form">
            Create Form
        </MudButton>
    </div>

    <!-- Forms List -->
    @if (isLoading)
    {
        <div style="text-align: center; padding: 100px 0;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" aria-label="Loading your forms" />
            <MudText Typo="Typo.body1" Class="mt-4" Color="Color.Secondary">Gathering your forms...</MudText>
        </div>
    }
    else if (forms == null || forms.Count == 0)
    {
        <!-- Empty State -->
        <div class="d-flex flex-column align-center justify-center py-16 px-8 rounded-xl" style="background: rgba(255,255,255,0.5); backdrop-filter: blur(4px); border: 2px dashed #cbd5e1;">
            <div class="mb-6 p-6 rounded-circle" style="background: white; box-shadow: 0 10px 15px -3px rgba(0,0,0,0.05);">
                <MudIcon Icon="@Icons.Material.Filled.Description" Style="font-size: 64px; color: #94a3b8;" aria-hidden="true" />
            </div>
            <MudText Typo="Typo.h5" Class="premium-header-text mb-2">No Forms Found</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-8 text-center" Style="max-width: 400px;">
                You haven't created any forms yet. Start building your first project today!
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick='@(() => Navigation.NavigateTo("editor"))'
                       Size="Size.Large"
                       Class="premium-btn px-8"
                       aria-label="Create your first form">
                Start Building
            </MudButton>
        </div>
    }
    else
    {
        <!-- Forms Grid -->
        <MudGrid Spacing="4">
            @foreach (var form in forms)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard Elevation="0" Class="premium-card d-flex flex-column" Style="height: 100%;">
                        <MudCardContent Class="flex-grow-1 pa-6">
                            <div class="d-flex justify-space-between align-start mb-4">
                                <div class="p-3 rounded-lg" style="background: #f1f5f9;">
                                    <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
                                </div>
                                <MudChip T="string" Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Style="background: #eef2ff; font-weight: 600;">@(form.Category ?? "Form")</MudChip>
                            </div>

                            <MudText Typo="Typo.h6" Class="premium-header-text mb-2">
                                @form.Name
                            </MudText>

                            @if (!string.IsNullOrEmpty(form.Description))
                            {
                                <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4" Style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 40px;">
                                    @form.Description
                                </MudText>
                            }

                            <div class="d-flex align-center gap-2 mt-4 pt-4" style="border-top: 1px solid #f1f5f9;">
                                <MudIcon Icon="@Icons.Material.Filled.AccessTime" Size="Size.Small" Color="Color.Secondary" />
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Last edit @GetRelativeTime(form.UpdatedAt)
                                </MudText>
                            </div>
                        </MudCardContent>

                        <MudCardActions Class="pa-4 pt-0">
                            <MudTooltip Text="Edit Form">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="() => OpenForm(form.Id)" />
                            </MudTooltip>
                            <MudTooltip Text="Share">
                                <MudIconButton Icon="@Icons.Material.Filled.Share" Color="Color.Secondary" OnClick="() => ShareForm(form.Id)" />
                            </MudTooltip>
                            <MudTooltip Text="Duplicate">
                                <MudIconButton Icon="@Icons.Material.Filled.ContentCopy" Color="Color.Default" OnClick="() => DuplicateForm(form.Id)" />
                            </MudTooltip>
                            
                            <MudSpacer />
                            
                            <MudTooltip Text="Delete">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(async () => await DeleteForm(form.Id, form.Name))" />
                            </MudTooltip>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudContainer>
</main>


@code {
    private List<FormMaker.Shared.Models.TemplateResponse>? forms;
    private bool isLoading = true;

    [Inject]
    private LocalStorageService LocalStorage { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = default!;

    [Inject]
    private IDialogService DialogService { get; set; } = default!;

    [Inject]
    private ApiService ApiService { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadForms();
    }

    private async Task LoadForms()
    {
        isLoading = true;
        try
        {
            // Load from API instead of localStorage
            var response = await ApiService.GetAsync<FormMaker.Shared.Models.TemplateListResponse>("templates");
            forms = response?.Templates ?? new List<FormMaker.Shared.Models.TemplateResponse>();
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error loading forms from server: {ex.Message}", Severity.Error);
            forms = new List<FormMaker.Shared.Models.TemplateResponse>();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading forms: {ex.Message}", Severity.Error);
            forms = new List<FormMaker.Shared.Models.TemplateResponse>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenForm(Guid formId)
    {
        Navigation.NavigateTo($"/editor?id={formId}");
    }

    private async Task ShareForm(Guid formId)
    {
        try
        {
            // Load the form template from API
            var templateResponse = await ApiService.GetAsync<FormMaker.Shared.Models.TemplateResponse>($"templates/{formId}");
            if (templateResponse == null)
            {
                Snackbar.Add("Form not found", Severity.Error);
                return;
            }

            // Parse the JsonData to get FormTemplate
            var template = System.Text.Json.JsonSerializer.Deserialize<FormMaker.Shared.Models.FormTemplate>(templateResponse.JsonData);
            if (template == null)
            {
                Snackbar.Add("Error parsing form data", Severity.Error);
                return;
            }

            // Open share dialog
            var parameters = new DialogParameters
            {
                ["Template"] = template
            };

            var options = new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                CloseButton = true,
                CloseOnEscapeKey = true
            };

            await DialogService.ShowAsync<ShareFormDialog>("Share Form", parameters, options);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error sharing form: {ex.Message}", Severity.Error);
        }
    }

    private async Task DuplicateForm(Guid formId)
    {
        try
        {
            // Get the original template from API
            var originalTemplate = await ApiService.GetAsync<FormMaker.Shared.Models.TemplateResponse>($"templates/{formId}");
            if (originalTemplate != null)
            {
                // Create a new template request with copied data
                var duplicateRequest = new FormMaker.Shared.Models.CreateTemplateRequest
                {
                    Name = $"{originalTemplate.Name} (Copy)",
                    Description = originalTemplate.Description,
                    JsonData = originalTemplate.JsonData,
                    Category = originalTemplate.Category,
                    Tags = originalTemplate.Tags,
                    IsPublic = false
                };

                // POST to API to create duplicate
                await ApiService.PostAsync<FormMaker.Shared.Models.CreateTemplateRequest, FormMaker.Shared.Models.TemplateResponse>("templates", duplicateRequest);
                Snackbar.Add("Form duplicated successfully!", Severity.Success);

                // Reload the forms list
                await LoadForms();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error duplicating form: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteForm(Guid formId, string formName)
    {
        var parameters = new DialogParameters
        {
            ["Content"] = $"Are you sure you want to delete '{formName}'? This action cannot be undone.",
            ["ConfirmText"] = "Delete",
            ["ConfirmColor"] = Color.Error
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            CloseButton = false,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Delete Form", parameters, options);
        var result = await dialog.Result;

        // Check if user canceled or didn't confirm
        if (result == null || result.Canceled)
        {
            return;
        }

        // Verify the user actually confirmed (Data should be true)
        if (result.Data is not bool confirmed || !confirmed)
        {
            return;
        }

        try
        {
            // DELETE from API
            var success = await ApiService.DeleteAsync($"templates/{formId}");
            if (success)
            {
                Snackbar.Add($"'{formName}' deleted", Severity.Info);
                await LoadForms();
            }
            else
            {
                Snackbar.Add($"Failed to delete '{formName}'", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error deleting form: {ex.Message}", Severity.Error);
        }
    }

    private string GetRelativeTime(DateTime dateTime)
    {
        var timeSpan = DateTime.UtcNow - dateTime;

        if (timeSpan.TotalMinutes < 1)
            return "just now";
        if (timeSpan.TotalMinutes < 60)
            return $"{(int)timeSpan.TotalMinutes} min ago";
        if (timeSpan.TotalHours < 24)
            return $"{(int)timeSpan.TotalHours} hours ago";
        if (timeSpan.TotalDays < 7)
            return $"{(int)timeSpan.TotalDays} days ago";
        if (timeSpan.TotalDays < 30)
            return $"{(int)(timeSpan.TotalDays / 7)} weeks ago";

        return dateTime.ToString("MMM d, yyyy");
    }
}
