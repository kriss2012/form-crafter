    // Share Form method
    private async Task OpenShareDialog()
    {
        // Save form first if it hasn't been saved
        if (currentTemplate.Id == Guid.Empty)
        {
            await SaveForm();

            // If save failed (template still has empty ID), don't proceed
            if (currentTemplate.Id == Guid.Empty)
            {
                Snackbar.Add("Please save the form before sharing", Severity.Warning);
                return;
            }
        }

        // Open share dialog
        var parameters = new DialogParameters
        {
            { "Template", currentTemplate }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        await DialogService.ShowAsync<ShareFormDialog>("Share Form", parameters, options);
    }

